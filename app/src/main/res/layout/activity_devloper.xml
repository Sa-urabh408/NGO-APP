<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ===== HERO HEADER (matches user profile style) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#CC1A237E"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="60dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Developer"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== PROFILE PHOTO (overlapping header like user profile) ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-55dp"
                android:gravity="center_horizontal">

                <!-- White circle border -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/circle_white_bg">

                    <ImageView
                        android:id="@+id/dev_image"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_image_bg"
                        android:clipToOutline="true"
                        android:contentDescription="Developer Photo"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dev1" />
                </FrameLayout>
            </FrameLayout>

            <!-- Name + Role below photo -->
            <TextView
                android:id="@+id/dev_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:text="Saurabh Kalamkar"
                android:textColor="#1A237E"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dev_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:background="#331A237E"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:text="Android Developer • UI Designer"
                android:textColor="#1A237E"
                android:textSize="13sp" />

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:text="📍 Nagpur, Maharashtra"
                android:textColor="#555555"
                android:textSize="13sp" />

            <!-- ===== CARDS SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <!-- About Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#EBC5C5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ABOUT"
                            android:textColor="#1A237E"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/dev_bio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="I'm Saurabh Kalamkar, a passionate Android Developer from Nagpur. I love building clean, beautiful and functional mobile apps that make a difference."
                            android:textColor="#444444"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.6" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Contact Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#EBC5C5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONTACT"
                            android:textColor="#1A237E"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="14dp" />

                        <!-- Email row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="#1A1A237E"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_dialog_email"
                                android:contentDescription="Email" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Email"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/dev_email"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="saurabhkalamkar07@gmail.com"
                                    android:textColor="#212121"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Phone row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="#1A1A237E"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_menu_call"
                                android:contentDescription="Phone" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Phone"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/dev_mobile"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8766062346"
                                    android:textColor="#212121"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Skills Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#EBC5C5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SKILLS"
                            android:textColor="#1A237E"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="14dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Android" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip" android:layout_marginEnd="8dp"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Java" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip" android:layout_marginEnd="8dp"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Firebase" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="XML" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip" android:layout_marginEnd="8dp"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="UI Design" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip" android:layout_marginEnd="8dp"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Git" android:textColor="#1A237E" android:textSize="12sp"
                                android:background="@drawable/skill_chip"
                                android:paddingStart="12dp" android:paddingEnd="12dp"
                                android:paddingTop="6dp" android:paddingBottom="6dp"/>
                        </LinearLayout>

                        <!-- Hidden view kept for Java compat -->
                        <TextView android:id="@+id/dev_skills"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Links Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#EBC5C5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOCIAL LINKS"
                            android:textColor="#1A237E"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="14dp" />

                        <!-- GitHub Row -->
                        <LinearLayout
                            android:id="@+id/btn_github"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingVertical="10dp"
                            android:layout_marginBottom="4dp">

                            <LinearLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="#1A1A237E"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_github"
                                    app:tint="#1A237E" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GitHub"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/dev_links"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="github.com/Sa-urabh408"
                                    android:textColor="#1A237E"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textColor="#1A237E"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#15000000"
                            android:layout_marginVertical="6dp" />

                        <!-- Instagram Row -->
                        <LinearLayout
                            android:id="@+id/btn_instagram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingVertical="10dp">

                            <LinearLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="#1AE1306C"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_instagram"
                                    app:tint="#E1306C" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Instagram"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/dev_instagram"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@saurabhkalamkar_"
                                    android:textColor="#1A237E"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textColor="#E1306C"
                                android:textSize="20sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Thank You Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#D07B7B">

                    <LinearLayout
                        android:layout_width="371dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/dev_thanks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text=" Thank You For Using Our NGO App!"
                            android:textColor="#1A237E"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- FOOTER NAV -->
    <include layout="@layout/footernav" />

</LinearLayout>
