<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical"
    android:background="@drawable/nav_bar_bg"
    android:elevation="12dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/nav_unselected"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/footer_home_icon"
            android:src="@drawable/home2"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Home" />

        <TextView
            android:id="@+id/footer_home_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="10sp"
            android:textColor="#555555"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- Donation -->
    <LinearLayout
        android:id="@+id/nav_donation"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/nav_unselected"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/footer_donation"
            android:src="@drawable/donation"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Donation" />

        <TextView
            android:id="@+id/footer_donation_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donate"
            android:textSize="10sp"
            android:textColor="#555555"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- User / Profile -->
    <LinearLayout
        android:id="@+id/nav_user"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/nav_unselected"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/footer_user"
            android:src="@drawable/user"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Profile" />

        <TextView
            android:id="@+id/footer_user_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="#555555"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- Developer -->
    <LinearLayout
        android:id="@+id/nav_dev"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/nav_unselected"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/footer_developer"
            android:src="@drawable/dev"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Developer" />

        <TextView
            android:id="@+id/footer_dev_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dev"
            android:textSize="10sp"
            android:textColor="#555555"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <!-- Logout -->
    <LinearLayout
        android:id="@+id/nav_logout"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/nav_unselected"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/footer_logout"
            android:src="@drawable/logout"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Logout" />

        <TextView
            android:id="@+id/footer_logout_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textSize="10sp"
            android:textColor="#555555"
            android:layout_marginTop="3dp" />
    </LinearLayout>

</LinearLayout>
